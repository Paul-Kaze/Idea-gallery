# Development environment configuration

# Supabase
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OSS (optional in dev)
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
OSS_REGION=cn-hangzhou
OSS_BUCKET=your-dev-bucket
OSS_KEY_PREFIX=ai-gallery-dev
OSS_ACCESS_KEY_ID=your-access-key-id
OSS_ACCESS_KEY_SECRET=your-access-key-secret

# Yunwu / Zhongzhuan model gateway
YUNWU_API_KEY=your-yunwu-api-key
YUNWU_BASE_URL=https://api.zhongzhuan.chat

# iShencai image generation gateway
ISHENCAI_API_KEY=your-ishencai-api-key
ISHENCAI_ENDPOINT=https://restapidev.ishencai.com/admin/api/ai/media/generate-sync

# Google OAuth
GOOGLE_CLIENT_ID=dev-google-client-id
GOOGLE_CLIENT_SECRET=dev-google-client-secret

NODE_ENV=development
